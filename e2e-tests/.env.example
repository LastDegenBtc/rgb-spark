# rgb-spark-e2e — environment template. Copy to .env and fill in.
#
# FUNDING_SEED_HEX: 32-byte hex of the master test wallet's seed. Generated
# automatically by `npm run setup` on first run; persisted to .env so all
# scenarios reuse the same funding wallet (= no need to re-fund per run).
# Mainnet wallet. Do NOT commit. The .env file is gitignored.
FUNDING_SEED_HEX=

# RELAY_BASE_URL: HTTP base of the consignment + orderbook + registry
# relay. Local dev defaults to http://localhost:5180. Override for a
# remote relay (e.g. https://dev.sprk.fun/relay).
RELAY_BASE_URL=http://localhost:5180

# SPARK_NETWORK: MAINNET / TESTNET / REGTEST. Real swaps cost real sats
# on mainnet; pick TESTNET if Spark exposes one (current SDK 0.7.x is
# mainnet-only).
SPARK_NETWORK=MAINNET
