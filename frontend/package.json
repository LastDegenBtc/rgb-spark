{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "test \"$CONFIRM_PROD_BUILD\" = \"1\" || (printf '\\n\\033[31m⛔ Refusing: this build writes dist/.\\033[0m Once this repo is wired to a prod server, every successful build deploys live.\\n   Use \"npm run build:check\" for a sandboxed compile, or set CONFIRM_PROD_BUILD=1 to deploy intentionally.\\n\\n' && exit 1) && tsc -b && vite build",
    "build:check": "tsc -b && vite build --outDir dist-check --emptyOutDir",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@buildonspark/spark-sdk": "^0.7.17",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "nostr-tools": "^2.23.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
